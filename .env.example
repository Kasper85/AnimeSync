# Archivo de configuración de ejemplo
# COPIA ESTE ARCHIVO COMO .env Y COMPLETA LOS VALORES

# Obtener en https://my.telegram.org/apps
API_ID=

# Obtener en https://my.telegram.org/apps
API_HASH=

# Número en formato internacional (con código de país)
PHONE=

# Username del canal (sin @) o ID numérico (ej: -1001234567890)
CHANNEL=